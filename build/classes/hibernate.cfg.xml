<?xml version='1.0' encoding='UTF-8'?>    
<!DOCTYPE hibernate-configuration PUBLIC    
          "-//Hibernate/Hibernate Configuration DTD 5.3//EN"    
          "http://www.hibernate.org/dtd/hibernate-configuration-5.3.dtd">    
    
<hibernate-configuration>    
    
    <session-factory>    
        <property name="hbm2ddl.auto">update</property>    
        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQLDialect</property>    
        <property name="hibernate.connection.url">jdbc:postgresql://localhost:5432/postgres</property>    
        <property name="hibernate.connection.username">postgres</property>    
        <property name="hibernate.connection.password">123</property>    
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>  
        <property name="hibernate.show_sql">true</property>  
     <mapping class="Modelo.Computadora"/>
     <mapping class="Modelo.hardware"/>
     <mapping class="Modelo.software"/>
     <mapping class="Modelo.sistemaOperativo"/>
     <mapping class="Modelo.Usuario"/>
     <mapping class="Modelo.Logins"/>
     <mapping class="Modelo.Cambios"/>
     <mapping class="Modelo.Incidencias"/>
     <mapping class="Modelo.Administrador"/>
     <mapping class="Modelo.TelfMovil"/>
     <mapping class="Modelo.TelfVOIP"/>
     <mapping class="Modelo.DispRED"/>
     <mapping class="Modelo.Mantenimiento"/>
     <mapping class="Modelo.existenciaXYear"/>
     <mapping class="Modelo.Eventos"/>
    </session-factory>    
    
</hibernate-configuration>