		<parameter name="ip_equipo" class="java.lang.String"/>
		<query language="plsql"><![CDATA[SELECT row_number() OVER(PARTITION BY ip) pos, cambios.tipo as cambio, componenteanterior, componenteactual, fecha, hora FROM computadora LEFT JOIN cambios
