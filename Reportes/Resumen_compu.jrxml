	<query language="plsql"><![CDATA[SELECT row_number() OVER (ORDER BY a.id) AS pos, a.nombrered, a.tipo, a.estado, a.ip, a.departamento, a.numsello,
b.nombre AS nombre_so, b.edicion AS edicion_so, b.version AS version_so,
c.nombre AS usuario, d.marca AS marca_cpu, d.modelo AS modelo_cpu, e.marca AS marca_ram, e.modelo AS modelo_ram, e.capacidad AS capacidad_ram
FROM computadora a
LEFT JOIN sistemaoperativo b ON b.id = a.so_id
LEFT JOIN usuario c ON c.id = a.usuario_id
LEFT JOIN hardware d ON d.equipoid = a.id AND d.tipo = 'CPU'
LEFT JOIN hardware e ON e.equipoid = a.id AND e.tipo = 'RAM';]]></query>
