	<dataset name="Dataset1" uuid="711dc09c-0e20-4fab-86e6-67445f959b50">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Sample DB"/>
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<query language="plsql"><![CDATA[SELECT count(*) as total_equipos, 
(select count(*) from (select count(*) from mantenimiento group by area)) as cant_areas,
(select count(*) from mantenimiento where primermantenimiento= 'General') as cant_mantenimiento_I_general,
(select count(*) from mantenimiento where primermantenimiento= 'Parcial') as cant_mantenimiento_I_parcial,
(select count(*) from mantenimiento where segundomantenimiento= 'General') as cant_mantenimiento_II_general,
(select count(*) from mantenimiento where segundomantenimiento= 'Parcial') as cant_mantenimiento_II_parcial
FROM mantenimiento;]]></query>
		<field name="total_equipos" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="total_equipos"/>
			<property name="com.jaspersoft.studio.field.label" value="total_equipos"/>
		</field>
		<field name="cant_areas" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="cant_areas"/>
			<property name="com.jaspersoft.studio.field.label" value="cant_areas"/>
		</field>
		<field name="cant_mantenimiento_i_general" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="cant_mantenimiento_i_general"/>
			<property name="com.jaspersoft.studio.field.label" value="cant_mantenimiento_i_general"/>
		</field>
		<field name="cant_mantenimiento_i_parcial" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="cant_mantenimiento_i_parcial"/>
			<property name="com.jaspersoft.studio.field.label" value="cant_mantenimiento_i_parcial"/>
		</field>
		<field name="cant_mantenimiento_ii_general" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="cant_mantenimiento_ii_general"/>
			<property name="com.jaspersoft.studio.field.label" value="cant_mantenimiento_ii_general"/>
		</field>
		<field name="cant_mantenimiento_ii_parcial" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="cant_mantenimiento_ii_parcial"/>
			<property name="com.jaspersoft.studio.field.label" value="cant_mantenimiento_ii_parcial"/>
		</field>
	</dataset>
	<dataset name="Dataset2" uuid="d1358d0b-ea01-4daa-a0f5-86b7e64cdea9">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Sample DB"/>
		<query language="plsql"><![CDATA[SELECT count(*) as total_equipos, 
(select count(*) from mantenimiento where cumplimiento= true) as cumplidos
FROM mantenimiento;]]></query>
		<field name="total_equipos" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="total_equipos"/>
			<property name="com.jaspersoft.studio.field.label" value="total_equipos"/>
		</field>
		<field name="cumplidos" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="cumplidos"/>
			<property name="com.jaspersoft.studio.field.label" value="cumplidos"/>
		</field>
		<variable name="indice_cumplimiento" resetType="None" class="java.lang.String">
			<expression><![CDATA[((java.util.function.Supplier<String>)()->{
	String indice;
	Long parte= $F{cumplidos};
    Long total= $F{total_equipos};
    if(total.equals(0)) return "No disponible";
    double porCiento= parte * 100 / total;
    if(porCiento == 0) indice= "No disponible";
    else if(porCiento <= 80l) indice= "Índice: 0";
    else if(porCiento >= 81l && porCiento <= 99l) indice= "Índice: 3";
    else indice= "Índice: 5";
    return indice;
}).get()]]></expression>
		</variable>
	</dataset>
	<query language="plsql"><![CDATA[SELECT * FROM mantenimiento ORDER BY area;]]></query>
