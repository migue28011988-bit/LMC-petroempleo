	<query language="plsql"><![CDATA[SELECT numerotelf, email, pin, puk, marca, modelo, numserie, usuario.nombre as nombreusuario
FROM telfmovil LEFT JOIN usuario ON telfmovil.usuario_id = usuario.id;]]></query>
