	<query language="plsql"><![CDATA[SELECT a.id as equipoid, a.nombrered as "Nombre de la red", a.tipo as "Tipo", a.ip as "Número de Ip", a.numsello as "No. de sello", a.numllavero as "No. de llavero", 
a.departamento as "Departamento", CONCAT(b.nombre, ' ', b.edicion, ' v', b.version) as "Sistema Operativo", 
c.nombre as "Usuario", cpu.marca || ' ' || cpu.modelo as "CPU", mb.marca as "mb_marca", mb.modelo as "mb_modelo", mb.numserie as "mb_no.serie",
ram.marca as "ram_marca", ram.modelo as ram_modelo, ram.capacidad as "ram_capacidad",
lector3_1_2.marca as "lector3_1_2_marca", lector3_1_2.modelo as "lector3_1_2_modelo", lector3_1_2.numserie as "lector3_1_2_no.serie",
cd_dvd.marca as "cd_dvd_marca", cd_dvd.modelo as "cd_dvd_modelo", cd_dvd.numserie as "cd_dvd_no.serie",
fuente.marca as "fuente_marca", fuente.modelo as "fuente_modelo", fuente.numserie as "fuente_no.serie",
teclado.marca as "teclado_marca", teclado.modelo as "teclado_modelo", teclado.numserie as "teclado_no.serie",
mouse.marca as "mouse_marca", mouse.modelo as "mouse_modelo", mouse.numserie as "mouse_no.serie",
speaker.marca as "bocinas_marca", speaker.modelo as "bocinas_modelo", speaker.numserie as "bocinas_no.serie",
chasis.marca as "chasis_marca", chasis.numserie as "chasis_no.serie", chasis.numinventario as "chasis_no.inventario",
UPS.marca as "UPS_marca", UPS.modelo as "UPS_modelo", UPS.numserie as "UPS_no.serie", UPS.numinventario as "UPS_no.inventario",
imp.marca as "imp_marca", imp.modelo as "imp_modelo", imp.numserie as "imp_no.serie", imp.numinventario as "imp_no.inventario",
scan.marca as "scan_marca", scan.modelo as "scan_modelo", scan.numserie as "scan_no.serie", scan.numinventario as "scan_no.inventario",
fotocopy.marca as "fotocopy_marca", fotocopy.modelo as "fotocopy_modelo", fotocopy.numserie as "fotocopy_no.serie", fotocopy.numinventario as "fotocopy_no.inventario"
FROM computadora a LEFT JOIN sistemaoperativo b ON b.id = a.so_id LEFT JOIN usuario c ON c.id = a.usuario_id 
LEFT JOIN hardware cpu ON cpu.equipoid = a.id AND cpu.tipo = 'CPU'
LEFT JOIN hardware mb ON mb.equipoid = a.id AND mb.tipo = 'Motherboard'
LEFT JOIN hardware ram ON ram.equipoid = a.id AND ram.tipo = 'RAM'
LEFT JOIN hardware lector3_1_2 ON lector3_1_2.equipoid = a.id AND lector3_1_2.tipo = 'Lector 3 1/2'
LEFT JOIN hardware cd_dvd ON cd_dvd.equipoid = a.id AND cd_dvd.tipo = 'Lector CD/DVD'
LEFT JOIN hardware fuente ON fuente.equipoid = a.id AND fuente.tipo = 'Fuente'
LEFT JOIN hardware teclado ON teclado.equipoid = a.id AND teclado.tipo = 'Teclado'
LEFT JOIN hardware mouse ON mouse.equipoid = a.id AND mouse.tipo = 'Mouse'
LEFT JOIN hardware speaker ON speaker.equipoid = a.id AND speaker.tipo = 'Bocinas'
LEFT JOIN hardware chasis ON chasis.equipoid = a.id AND chasis.tipo = 'Chasis'
LEFT JOIN hardware UPS ON UPS.equipoid = a.id AND UPS.tipo = 'UPS'
LEFT JOIN hardware imp ON imp.equipoid = a.id AND imp.tipo = 'Impresora'
LEFT JOIN hardware scan ON scan.equipoid = a.id AND scan.tipo = 'Scanner'
LEFT JOIN hardware fotocopy ON fotocopy.equipoid = a.id AND fotocopy.tipo = 'Fotocopiadora'
ORDER BY a.nombrered;]]></query>
