	<query language="plsql"><![CDATA[SELECT codigo, numinventario, ip, marca, modelo, numserie,
departamento, nombre as nombreUsuario
FROM telfvoip LEFT JOIN usuario ON telfvoip.usuario_id = usuario.id;]]></query>
